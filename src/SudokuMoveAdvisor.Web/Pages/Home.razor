@page "/"

@using SudokuMoveAdvisor.Core.Models
@using SudokuMoveAdvisor.Core.Services

<PageTitle>Sudoku Move Advisor</PageTitle>

<h1>Sudoku Move Advisor</h1>

<p>Gib ein Sudoku mit 81 Zeichen ein: Ziffern 1-9 oder Punkt für leere Felder.</p>

<div class="mb-3">
    <textarea class="form-control" @bind="Puzzle" rows="6" placeholder=".3..7..1.."></textarea>
</div>

<button class="btn btn-primary mb-3" @onclick="Analyze">Analysieren</button>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
else if (Suggestion is not null)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Vorgeschlagener Zug</h5>
            <p>Zeile <strong>@Suggestion.Row</strong>, Spalte <strong>@Suggestion.Column</strong> = <strong>@Suggestion.Value</strong></p>
            <p><strong>Strategie:</strong> @Suggestion.Strategy</p>
            <p><strong>Begründung:</strong> @Suggestion.Reason</p>
            @if (Suggestion.Candidates.Count > 0)
            {
                <p><strong>Kandidaten:</strong> @string.Join(", ", Suggestion.Candidates)</p>
            }
        </div>
    </div>

    <pre class="border rounded p-3 bg-light">@BoardDisplay</pre>
}

@code {
    private string Puzzle { get; set; } = string.Empty;
    private string? ErrorMessage;
    private SudokuMoveSuggestion? Suggestion;
    private string? BoardDisplay;

    private void Analyze()
    {
        ErrorMessage = null;
        Suggestion = null;
        BoardDisplay = null;

        try
        {
            var parser = new SudokuParser();
            var analyzer = new SudokuAnalyzer();
            var board = parser.Parse(Puzzle);
            var suggestion = analyzer.SuggestNextMove(board);

            if (suggestion is null)
            {
                ErrorMessage = "Kein nächster erklärbarer Zug gefunden.";
                return;
            }

            Suggestion = suggestion;
            BoardDisplay = board.ToPrettyString();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
}
